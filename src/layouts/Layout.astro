---
interface Props {
	title?: string;
	description?: string;
}

const { title = "Mi Portafolio", description = "Portafolio web personal" } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-slate-200 font-sans antialiased min-h-screen relative overflow-x-hidden">
		<div class="fixed inset-0 -z-10">
			<div class="absolute top-[-10%] left-[10%] w-[500px] h-[500px] bg-purple-600/30 rounded-full blur-[128px]"></div>
			<div class="absolute bottom-[-5%] right-[10%] w-[400px] h-[400px] bg-pink-600/20 rounded-full blur-[128px]"></div>
			<div class="absolute top-[40%] right-[20%] w-[300px] h-[300px] bg-indigo-600/20 rounded-full blur-[128px]"></div>
		</div>
		<slot />
	</body>
</html>
